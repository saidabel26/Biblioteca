{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "shell",
            "label": "Compilar proyecto",
            "command": "C:\\TDM-GCC-64\\bin\\g++.exe",
            "args": [
                "-Wall",
                "-Wextra",
                "-g3",
                "${workspaceFolder}\\*.cpp",
                "-o",
                "${workspaceFolder}\\output\\main.exe"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": ["$gcc"],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}